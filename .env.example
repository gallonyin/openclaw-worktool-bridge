# ===== Core =====
PYTHONUNBUFFERED=1
WEB_PORT=8080

# ===== MySQL(Container) =====
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=worktool_bridge
MYSQL_USER=worktool
MYSQL_PASSWORD=change_me_app

# ===== App MySQL =====
APP_MYSQL_HOST=mysql
APP_MYSQL_PORT=3306
APP_MYSQL_USER=worktool
APP_MYSQL_PASSWORD=change_me_app
APP_MYSQL_DATABASE=worktool_bridge
APP_MYSQL_TIME_ZONE=+08:00

# ===== JWT =====
AUTH_JWT_SECRET=change_me_to_random_32_plus_chars
AUTH_JWT_EXPIRE_DAYS=30
AUTH_PBKDF2_ITERATIONS=390000
AUTH_SMS_ENABLED=false
ENABLE_RUNTIME_WORKTOOL_SETTINGS=false
WORKTOOL_API_BASE=https://api.worktool.ymdyes.cn
CALLBACK_PUBLIC_BASE_URL=
ADMIN_PHONE_WHITELIST=
WORKTOOL_DB_HOST=
WORKTOOL_DB_PORT=3306
WORKTOOL_DB_USER=
WORKTOOL_DB_PASSWORD=
WORKTOOL_DB_NAME=

# ===== SMS(HuaRui) =====
SMS_HUARUI_API_URL=
SMS_HUARUI_APPKEY=
SMS_HUARUI_APPSECRET=
SMS_CODE_EXPIRE_MINUTES=15

# ===== Default Test Provider (shared for all users) =====
DEFAULT_TEST_PROVIDER_ENABLED=false
DEFAULT_TEST_PROVIDER_NAME=AI模型(仅测试用)
DEFAULT_TEST_PROVIDER_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3/chat/completions
DEFAULT_TEST_PROVIDER_API_KEY=
DEFAULT_TEST_PROVIDER_MODEL=doubao-seed-2.0-lite
